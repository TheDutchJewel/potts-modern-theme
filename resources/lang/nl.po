#: resources/views/admin/settings.phtml:136
msgid "The Potts Modern settings have been saved."
msgstr "De Potts Modern-instellingen zijn opgeslagen."

#: resources/views/admin/settings.phtml:139
msgid "The Potts Modern defaults have been restored."
msgstr "De standaardinstellingen van Potts Modern zijn hersteld."

#: resources/views/admin/settings.phtml:145
msgid ""
"These settings apply site-wide whenever Potts Modern is the selected theme. "
"Changes are easy to reverse using Restore defaults."
msgstr ""
"Deze instellingen gelden voor de hele site wanneer Potts Modern als thema is "
"geselecteerd. Wijzigingen kunnen eenvoudig worden teruggedraaid via "
"Standaardinstellingen herstellen."

#: resources/views/admin/settings.phtml:156
msgid "Appearance"
msgstr "Weergave"

#: resources/views/admin/settings.phtml:158
msgid "Colour palette"
msgstr "Kleurenpalet"

#: resources/views/admin/settings.phtml:158
msgid "Choose the overall heritage colour scheme."
msgstr "Kies het algemene erfgoedkleurenschema."

#: resources/views/admin/settings.phtml:159
msgid "Text size"
msgstr "Tekstgrootte"

#: resources/views/admin/settings.phtml:159
msgid "Increase base text across the public site."
msgstr "Vergroot de standaardtekst op de hele site."

#: resources/views/admin/settings.phtml:160
msgid "Card corners"
msgstr "Kaarthoeken"

#: resources/views/admin/settings.phtml:160
msgid "Control how rounded cards, panels and controls appear."
msgstr "Bepaal hoe afgerond kaarten, panelen en bedieningselementen zijn."

#: resources/views/admin/settings.phtml:161
msgid "Card shadows"
msgstr "Kaartschaduwen"

#: resources/views/admin/settings.phtml:161
msgid "Choose a flatter or more dimensional appearance."
msgstr "Kies voor een vlakker of meer diepte-effect."

#: resources/views/admin/settings.phtml:166
msgid "Layout"
msgstr "Indeling"

#: resources/views/admin/settings.phtml:168
msgid "Page width"
msgstr "Paginabreedte"

#: resources/views/admin/settings.phtml:168
msgid "Standard suits most screens; Wide gives charts and books more room."
msgstr ""
"Standaard past op de meeste schermen; Breed geeft grafieken en boeken meer "
"ruimte."

#: resources/views/admin/settings.phtml:169
msgid "Content spacing"
msgstr "Afstand tussen inhoud"

#: resources/views/admin/settings.phtml:169
msgid "Adjust spacing within cards and between homepage blocks."
msgstr "Pas de ruimte binnen kaarten en tussen blokken op de startpagina aan."

#: resources/views/admin/settings.phtml:170
msgid "Individual-page sidebar"
msgstr "Zijbalk per pagina"

#: resources/views/admin/settings.phtml:170
msgid "Controls the width of the Family navigator on larger screens."
msgstr "Regelt de breedte van de gezinsnavigator op grotere schermen."

#: resources/views/admin/settings.phtml:175
msgid "Header and navigation"
msgstr "Kop en navigatie"

#: resources/views/admin/settings.phtml:177
msgid "Main icon size"
msgstr "Grootte hoofdiconen"

#: resources/views/admin/settings.phtml:177
msgid "Change the size of the modern genealogy menu icons."
msgstr "Verander de grootte van de moderne genealogie-menupictogrammen."

#: resources/views/admin/settings.phtml:178
msgid "Main menu display"
msgstr "Weergave hoofdmenu"

#: resources/views/admin/settings.phtml:178
msgid "Display modern icons with labels or use labels alone."
msgstr "Toon moderne pictogrammen met labels of alleen labels."

#: resources/views/admin/settings.phtml:181
msgid "Show the family photo strip"
msgstr "Familiefotobalk tonen"

#: resources/views/admin/settings.phtml:181
msgid "Display the rotating family photograph banner beneath the menu."
msgstr "Toon de roterende familiefotobanner onder het menu."

#: resources/views/admin/settings.phtml:182
msgid "Show modern dropdown icons"
msgstr "Moderne uitklappictogrammen tonen"

#: resources/views/admin/settings.phtml:182
msgid ""
"Use the refreshed line icons in Charts, Lists, Calendar and other dropdown "
"menus."
msgstr ""
"Gebruik de vernieuwde lijnpictogrammen in Diagrammen, Lijsten, Kalender en "
"andere uitklapmenu’s."

#: resources/views/admin/settings.phtml:183
msgid "Show modern fact and event icons"
msgstr "Moderne feit- en gebeurtenispictogrammen tonen"

#: resources/views/admin/settings.phtml:183
msgid ""
"Display consistent line icons beside Birth, Marriage, Occupation, Residence "
"and other facts."
msgstr ""
"Toon consistente lijnpictogrammen naast Geboorte, Huwelijk, Beroep, "
"Woonplaats en andere feiten."

#: resources/views/admin/settings.phtml:188
msgid "Accessibility"
msgstr "Toegankelijkheid"

#: resources/views/admin/settings.phtml:190
msgid "Larger controls"
msgstr "Grotere bedieningselementen"

#: resources/views/admin/settings.phtml:190
msgid "Increase the height of buttons, fields and selectors for easier use."
msgstr ""
"Vergroot de hoogte van knoppen, velden en keuzelijsten voor eenvoudiger "
"gebruik."

#: resources/views/admin/settings.phtml:191
msgid "Higher contrast"
msgstr "Hoger contrast"

#: resources/views/admin/settings.phtml:191
msgid "Strengthen borders, links and keyboard focus indicators."
msgstr "Versterk randen, links en focusindicatoren voor toetsenbordgebruik."

#: resources/views/admin/settings.phtml:192
msgid "Reduce animation"
msgstr "Animatie verminderen"

#: resources/views/admin/settings.phtml:192
msgid "Remove transitions and smooth scrolling throughout the theme."
msgstr "Verwijder overgangen en vloeiend scrollen in het hele thema."

#: resources/views/admin/settings.phtml:197
msgid "Theme preview"
msgstr "Thema-voorbeeld"

#: resources/views/admin/settings.phtml:199
msgid "Preview"
msgstr "Voorbeeld"

#: resources/views/admin/settings.phtml:203
msgid "Family Tree"
msgstr "Stamboom"

#: resources/views/admin/settings.phtml:204
msgid "Search"
msgstr "Zoeken"

#: resources/views/admin/settings.phtml:209
msgid "Family history"
msgstr "Familiegeschiedenis"

#: resources/views/admin/settings.phtml:210
msgid "A preview of cards, text, navigation and heritage accents."
msgstr "Een voorbeeld van kaarten, tekst, navigatie en erfgoedaccenten."

#: resources/views/admin/settings.phtml:214
msgid "Individuals"
msgstr "Personen"

#: resources/views/admin/settings.phtml:215
msgid "Place hierarchy"
msgstr "Plaatsenhiërarchie"

#: resources/views/admin/settings.phtml:216
msgid "Sources"
msgstr "Bronnen"

#: resources/views/admin/settings.phtml:227
msgid "Save when you are happy with the preview."
msgstr "Opslaan wanneer u tevreden bent met het voorbeeld."

#: resources/views/admin/settings.phtml:228
msgid "A hard refresh may be needed after changing cached styles."
msgstr ""
"Een harde verversing kan nodig zijn na het wijzigen van gecachte stijlen."

#: resources/views/admin/settings.phtml:231
msgid "Restore all Potts Modern settings to their defaults?"
msgstr "Alle Potts Modern-instellingen herstellen naar de standaardwaarden?"

#: resources/views/admin/settings.phtml:231
msgid "Restore defaults"
msgstr "Standaardinstellingen herstellen"

#: resources/views/admin/settings.phtml:232
msgid "Save settings"
msgstr "Instellingen opslaan"
