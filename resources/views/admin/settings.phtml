<script>
(function(){
  const utilityControls=Array.from(document.querySelectorAll('a,button')).filter(el=>{
    if(el.closest('.potts-settings-page')){return false;}
    return /^(my page|theme|language|sign out|log out|logout)\b/i.test((el.textContent||'').replace(/\s+/g,' ').trim());
  });
  utilityControls.forEach(el=>{
    el.classList.add('potts-settings-header-link');
    const bar=el.closest('nav,header,.navbar,.wt-header,.wt-header-wrapper,#header,#top-header');
    if(bar){bar.classList.add('potts-settings-header-bar');}
  });
  const preview=document.getElementById('potts-theme-preview');
  if(!preview){return;}
  const palettes={heritage:{bg:'#f5efe4',bg2:'#fffaf2',ink:'#233038',muted:'#65717a',accent:'#185a71',dark:'#123b4b',gold:'#b98638',sage:'#e3eadf'},cool:{bg:'#eaf1f2',bg2:'#fbfefe',ink:'#203238',muted:'#61757a',accent:'#17677a',dark:'#104551',gold:'#8f9e67',sage:'#dfeceb'},sepia:{bg:'#eee4d3',bg2:'#fffaf1',ink:'#3d3026',muted:'#786a5d',accent:'#765038',dark:'#4e3424',gold:'#b27b33',sage:'#e7e5d7'},eucalyptus:{bg:'#edf1e9',bg2:'#fbfcf7',ink:'#26352e',muted:'#66736c',accent:'#416b56',dark:'#203e34',gold:'#a88a52',sage:'#dfe8dc'},claret:{bg:'#f2ece8',bg2:'#fffaf4',ink:'#342b2d',muted:'#74676a',accent:'#743c4a',dark:'#4d2731',gold:'#aa8954',sage:'#e4e8dc'}};
  function refresh(){
    const palette=document.querySelector('[name="palette"]').value;
    const corners=document.querySelector('[name="corners"]').value;
    const shadows=document.querySelector('[name="shadows"]').value;
    const text=document.querySelector('[name="text_size"]').value;
    const p=palettes[palette];
    const radius={soft:'20px',moderate:'13px',square:'3px'}[corners];
    const shadow={soft:'0 18px 42px rgba(35,48,56,.12)',strong:'0 22px 55px rgba(35,48,56,.22)',none:'none'}[shadows];
    preview.style.background='linear-gradient(180deg,'+p.bg2+','+p.bg+')';
    preview.style.color=p.ink;
    preview.style.borderRadius=radius;
    preview.style.boxShadow=shadow;
    preview.style.fontSize=text==='large'?'1.075rem':'1rem';
    preview.querySelector('.potts-preview-header').style.background='linear-gradient(135deg,'+p.dark+','+p.accent+')';
    preview.querySelectorAll('.potts-preview-card').forEach(el=>{el.style.borderRadius=radius;el.style.boxShadow=shadow;});
    preview.querySelectorAll('.potts-preview-chips span,.potts-submenu-demo i').forEach(el=>{el.style.background=p.sage;el.style.color=p.accent;});
    preview.querySelector('.potts-submenu-demo').style.background=p.bg2;
  }
  document.querySelectorAll('[data-potts-setting]').forEach(el=>el.addEventListener('change',refresh));
  refresh();
})();
</script>
