$select = static function (string $key, string $label, string $help) use ($settings, $choices): void {
    $name = strtolower($key);
    ?>
    <div class="potts-setting-field">
        <label class="form-label" for="potts-<?= e($name) ?>"><?= e($label) ?></label>
        <select class="form-select" id="potts-<?= e($name) ?>" name="<?= e($name) ?>" data-potts-setting="<?= e($name) ?>">
            <?php foreach ($choices[$key] as $value => $option) : ?>
                <option value="<?= e($value) ?>" <?= $settings[$key] === $value ? 'selected' : '' ?>><?= e($option) ?></option>
            <?php endforeach ?>
        </select>
        <div class="form-text"><?= e($help) ?></div>
    </div>
    <?php
};

$toggle = static function (string $key, string $label, string $help) use ($settings): void {
    $name = strtolower($key);
    ?>
    <label class="potts-setting-toggle" for="potts-<?= e($name) ?>">
        <span>
            <strong><?= e($label) ?></strong>
            <small><?= e($help) ?></small>
        </span>
        <span class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="potts-<?= e($name) ?>" name="<?= e($name) ?>" value="1" data-potts-setting="<?= e($name) ?>" <?= $settings[$key] === '1' ? 'checked' : '' ?>>
        </span>
    </label>
    <?php
};

$t = static fn (string $text): string => I18N::translate($text);
